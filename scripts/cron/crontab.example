# Optional manual cron triggers (fallback only).
# Production uses Vercel Cron — see backend/vercel.json.
#
# Linux/macOS manual setup:
#   cp scripts/cron/cron.env.example scripts/cron/cron.env
#   chmod +x scripts/cron/*.sh
#   crontab -e

*/15 * * * * /path/to/alhabeed/scripts/cron/sync-live-scores.sh >> /var/log/alhabeed-live-scores.log 2>&1
*/5 * * * * /path/to/alhabeed/scripts/cron/send-match-reminders.sh >> /var/log/alhabeed-match-reminders.log 2>&1
