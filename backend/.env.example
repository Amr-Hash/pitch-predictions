SECRET_KEY=dev-secret-key-change-in-production
DEBUG=True
DATABASE_URL=postgres://alhabeed:alhabeed@postgres:5432/alhabeed
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
JWT_SECRET=dev-jwt-secret
FRONTEND_URL=http://localhost:3000
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@localhost

# Live score sync (API-Football — https://www.api-football.com/)
API_FOOTBALL_KEY=
# Protects GET /api/cron/sync-live-scores (Vercel Cron sends Authorization: Bearer …)
CRON_SECRET=
# Optional manual webhook trigger for /api/tournaments/webhooks/live-scores/api-football
API_FOOTBALL_WEBHOOK_SECRET=
# Optional ISO dates; cron no-ops outside this window (defaults: no gating)
LIVE_SCORE_SYNC_START=2026-06-11
LIVE_SCORE_SYNC_END=2026-06-28
